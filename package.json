{
    "name": "@inivi/plaster-calculator",
    "type": "module",
    "private": true,
    "workspaces": [
        "apps/*",
        "functions/*",
        "libraries/*"
    ],
    "scripts": {
        "build": "tsc --build tsconfig.build.json",
        "admin-cli": "yarn workspace @apps/admin-cli build && node apps/admin-cli/out/main.js",
        "deploy": "firebase deploy",
        "deploy:dataconnect": "firebase deploy --only dataconnect",
        "deploy:functions": "firebase deploy --only functions",
        "deploy:storage": "firebase deploy --only storage",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint .",
        "start": "node ./scripts/predeploy-floorplan-analyzer-functions.mjs && yarn build && firebase emulators:start --import=./tmp/data/emulators --export-on-exit"
    },
    "devDependencies": {
        "@apps/admin-cli": "workspace:*",
        "@eslint/js": "^10.0.1",
        "eslint": "^10.4.0",
        "firebase-tools": "^15.18.0",
        "globals": "^17.6.0",
        "nx": "22.7.2",
        "prettier": "^3.8.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.3"
    },
    "packageManager": "yarn@4.14.1"
}
