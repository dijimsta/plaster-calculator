{
    "apphosting": {
        "backendId": "web",
        "rootDir": "./apps/plaster-calculator-web",
        "ignore": [
            "node_modules",
            ".next",
            ".git",
            "firebase-debug.log",
            "firebase-debug.*.log"
        ]
    },
    "dataconnect": {
        "source": "."
    },
    "functions": {
        "source": "functions/plaster-calculator-functions",
        "runtime": "nodejs24",
        "predeploy": [
            "yarn workspace @inivi/plaster-calculator-functions bundle"
        ]
    },
    "storage": {
        "rules": "storage.rules"
    },
    "emulators": {
        "apphosting": {
            "port": 5050,
            "rootDirectory": "./apps/plaster-calculator-web",
            "startCommand": "yarn dev"
        },
        "auth": {
            "port": 9099
        },
        "functions": {
            "port": 5001
        },
        "storage": {
            "port": 9199
        },
        "tasks": {
            "port": 9499
        },
        "ui": {
            "enabled": true
        },
        "singleProjectMode": true,
        "dataconnect": {
            "dataDir": "tmp/data/dataconnect"
        }
    }
}
