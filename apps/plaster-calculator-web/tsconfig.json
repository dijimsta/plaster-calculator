{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "composite": false,
        "jsx": "preserve",
        "plugins": [
            {
                "name": "next"
            },
            {
                "name": "typescript-plugin-css-modules"
            }
        ],
        "skipLibCheck": true
    },
    "include": ["next-env.d.ts", ".next/types/**/*.ts", "**/*.ts", "**/*.tsx"],
    "exclude": ["node_modules"]
}
