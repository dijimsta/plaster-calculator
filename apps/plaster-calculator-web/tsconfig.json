{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "jsx": "preserve",
        "plugins": [
            {
                "name": "next"
            },
            {
                "name": "typescript-plugin-css-modules"
            }
        ]
    },
    "include": [
        "next-env.d.ts",
        "**/*.css",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts"
    ],
    "exclude": ["node_modules"]
}
